# Force UTF-8 encoding and LF line endings for text files
# This prevents encoding corruption (garbled Chinese characters) on Windows

* text=auto eol=lf

# Explicitly mark all Markdown as text/UTF-8
*.md text eol=lf encoding=utf-8
*.txt text eol=lf

# Source code
*.go text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.xml text eol=lf

# Binary — do not touch
*.exe binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.drawio binary
