.claude/settings.local.json

# Build artifacts
*.exe
*.exe~
axis-dev*
axis.test*

# Coverage and profiling
*.out
coverage.*

# Local databases
*.rvf
*.rvf.lock
*.db

# Leaked hook output and exit codes
$GITHUB_STEP_SUMMARY,
$GITHUB_ENV
/0
/255
/61

# Stale markers
.milestone*-acceptance-marker

# Runtime state (axis start)
.axis/

# Third-party agent runtime state (claude-flow daemon, etc.)
.claude-flow/

# Auxiliary tools — non-invasive helpers that observe Axis through public
# interfaces. They have independent go.mod and MUST NOT import internal/.
# Source is tracked; build artifacts and dependencies are not.
/tools/axis-gui/axis-gui.exe
/tools/axis-gui/frontend/node_modules/
/tools/axis-gui/frontend/dist/
/tools/axis-up/axis-up.exe

# IDE local config
.windsurf/
.windsurfrules
.idea/
.vscode/


# External reference repos (read-only, not part of Axis)
EXTERNAL/

# Tool-local state
.kiro/*
!.kiro/agents/
.context-summary.md
