.claude/settings.local.json

# Build artifacts
*.exe
*.exe~
axis-dev*
axis.test*

# Coverage and profiling
*.out
coverage.*

# Local databases
*.rvf
*.rvf.lock
*.db

# Leaked hook output and exit codes
$GITHUB_STEP_SUMMARY,
$GITHUB_ENV
/0
/255
/61

# Stale markers
.milestone*-acceptance-marker

# Runtime state (axis start)
.axis/

# Third-party agent runtime state (claude-flow daemon, etc.)
.claude-flow/

# Auxiliary tools — non-invasive helpers (axis-gui TUI, axis-up updater).
# Sources live in their own repos; only compiled binaries land here on
# `axis-up install`. Never commit them to the core repo: this would
# leak 100MB+ of node_modules / .exe artefacts, drag the §1 "no Web/TUI
# in core" boundary into the main module graph, and pin a binary
# release into source history. See docs/tools/axis-up.md for how to
# fetch them locally.
# (Leading slash anchors to repo root so docs/tools/ is NOT ignored.)
/tools/

# IDE local config
.windsurf/
.windsurfrules
.idea/
.vscode/
